---
import type { MetricSeries } from '../lib/session-metrics';

interface Props {
  series: MetricSeries;
  // Viewbox dimensions. The SVG scales to its container via CSS; these just set
  // the coordinate system.
  width?: number;
  height?: number;
  pad?: number;
}

const { series, width = 320, height = 64, pad = 6 } = Astro.props;

const points = series.points;
const sessionMin = Math.min(...points.map((p) => p.session));
const sessionMax = Math.max(...points.map((p) => p.session));
const xDenom = Math.max(1, sessionMax - sessionMin);

// y-axis: anchor at zero for readability when values are small. Top extends to
// max, with a small top padding inside the viewBox.
const yMax = Math.max(series.max, 1);
const yMin = 0;
const yDenom = Math.max(1, yMax - yMin);

const plotLeft = pad;
const plotRight = width - pad;
const plotTop = pad;
const plotBottom = height - pad;

function x(session: number): number {
  const t = (session - sessionMin) / xDenom;
  return plotLeft + t * (plotRight - plotLeft);
}

function y(value: number): number {
  const t = (value - yMin) / yDenom;
  return plotBottom - t * (plotBottom - plotTop);
}

// Build the SVG path string, starting a new sub-path on undefined gaps so the
// line breaks cleanly instead of connecting across missing data.
let d = '';
let previousDefined = false;
for (const p of points) {
  if (p.value === undefined) {
    previousDefined = false;
    continue;
  }
  const cmd = previousDefined ? 'L' : 'M';
  d += `${cmd}${x(p.session).toFixed(2)},${y(p.value).toFixed(2)} `;
  previousDefined = true;
}

const definedPoints = points.filter(
  (p): p is { session: number; value: number } => p.value !== undefined,
);

// y-axis ticks: zero at the bottom, max at the top. Used as light reference.
const axisMaxLabel = yMax;
---

<div class="sparkline">
  <svg
    viewBox={`0 0 ${width} ${height}`}
    preserveAspectRatio="none"
    role="img"
    aria-label={`${series.def.label} from Session ${sessionMin} to Session ${sessionMax}`}
  >
    <!-- baseline (zero) -->
    <line
      x1={plotLeft}
      y1={plotBottom}
      x2={plotRight}
      y2={plotBottom}
      class="sparkline-axis"
    />
    {d && <path d={d} class="sparkline-line" fill="none" />}
    {definedPoints.map((p) => (
      <circle cx={x(p.session)} cy={y(p.value)} r="2.2" class="sparkline-dot" />
    ))}
  </svg>
  <div class="sparkline-scale" aria-hidden="true">
    <span>S{sessionMin}</span>
    <span>S{sessionMax}</span>
  </div>
  <div class="sparkline-yscale" aria-hidden="true">
    <span class="sparkline-ytop">{axisMaxLabel}</span>
    <span class="sparkline-ybot">0</span>
  </div>
</div>
