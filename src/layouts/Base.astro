---
import '../styles/global.css';
import { site } from '../site';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  activeNav?: 'home' | 'sessions' | 'concepts' | 'about';
}

const {
  title,
  description = site.metaDescription,
  wide = false,
  activeNav,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const clean = path.startsWith('/') ? path.slice(1) : path;
  const root = base.endsWith('/') ? base : `${base}/`;
  return `${root}${clean}`;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="site-title" href={withBase('')}>
          {site.hasBeenNamed
            ? site.title
            : (<>Field Notes from the <em>{site.methodologyNameBare}</em></>)}
        </a>
        <nav class="site-nav" aria-label="Primary">
          <a href={withBase('')} class={activeNav === 'home' ? 'active' : ''}>Home</a>
          <a href={withBase('sessions/')} class={activeNav === 'sessions' ? 'active' : ''}>Sessions</a>
          <a href={withBase('concepts/')} class={activeNav === 'concepts' ? 'active' : ''}>Concepts</a>
          <a href={withBase('about/')} class={activeNav === 'about' ? 'active' : ''}>About</a>
        </nav>
      </div>
    </header>
    <main class={wide ? 'wide' : ''}>
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        Written by {site.authorName} &nbsp;·&nbsp; Operator: {site.operatorName} &nbsp;·&nbsp; Last updated {site.lastUpdated}
      </p>
    </footer>
  </body>
</html>
