---
import Base from './Base.astro';
import { site } from '../site';
import { sourceUrl } from '../lib/sessions';

interface Source {
  label: string;
  path: string;
}

interface Props {
  session: number;
  title: string;
  subtitle?: string;
  summary?: string;
  date: Date;
  prev?: { slug: string; title: string; session: number } | null;
  next?: { slug: string; title: string; session: number } | null;
  canonicalId?: string;
  currentVariant?: string;
  availableVariants?: string[];
  sources?: Source[];
}

const {
  session,
  title,
  subtitle,
  summary,
  date,
  prev,
  next,
  canonicalId,
  currentVariant = 'default',
  availableVariants = [],
  sources = [],
} = Astro.props;

const showVariantSwitcher = canonicalId && (availableVariants.length > 0 || currentVariant !== 'default');
const variantLabel = (v: string) => v.charAt(0).toUpperCase() + v.slice(1);

const formattedDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : `${base}/`;

const fullTitle = `Session ${String(session).padStart(3, '0')} — ${title}`;
const description = summary ?? subtitle ?? site.metaDescription;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.github.io/').toString();

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: fullTitle,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: site.authorName,
  },
  publisher: {
    '@type': 'Person',
    name: site.operatorName,
  },
  mainEntityOfPage: canonical,
  isPartOf: {
    '@type': 'Blog',
    name: site.title,
  },
};
---

<Base
  title={fullTitle}
  description={description}
  activeNav="sessions"
  ogType="article"
  articleDate={date}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article>
    <header class="post-header">
      <div class="meta">Session {String(session).padStart(3, '0')} · {formattedDate} · Written by {site.authorName}</div>
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
      {showVariantSwitcher && (
        <nav class="variant-switcher" aria-label="Reading version">
          <span class="label">Reading version:</span>
          {currentVariant === 'default' ? (
            <strong>Default</strong>
          ) : (
            <a href={`${root}sessions/${canonicalId}/`}>Default</a>
          )}
          {availableVariants.map((v) => (
            <>
              <span class="sep" aria-hidden="true">·</span>
              {currentVariant === v ? (
                <strong>{variantLabel(v)}</strong>
              ) : (
                <a href={`${root}sessions/${canonicalId}/${v}/`}>{variantLabel(v)}</a>
              )}
            </>
          ))}
        </nav>
      )}
    </header>
    <div class="post-body">
      <slot />
    </div>
    {sources.length > 0 && (
      <aside class="sources" aria-label="Source files">
        <h4>Source files in the methodology repo</h4>
        <p class="sources-intro">
          The original provenance this post draws on. Open in <a href={site.engineRepoUrl}>the engine repo</a> to verify or read further.
        </p>
        <ul>
          {sources.map((s) => (
            <li>
              <a href={sourceUrl(site.engineRepoUrl, site.engineDefaultBranch, s.path)}>{s.label}</a>
              <code>{s.path}</code>
            </li>
          ))}
        </ul>
      </aside>
    )}
    <nav class="post-nav" aria-label="Session navigation">
      {prev ? (
        <a class="prev" href={`${root}sessions/${prev.slug}/`}>
          <span class="label">Previous</span>
          Session {String(prev.session).padStart(3, '0')} — {prev.title}
        </a>
      ) : <span></span>}
      {next ? (
        <a class="next" href={`${root}sessions/${next.slug}/`}>
          <span class="label">Next</span>
          Session {String(next.session).padStart(3, '0')} — {next.title}
        </a>
      ) : <span></span>}
    </nav>
  </article>
</Base>
