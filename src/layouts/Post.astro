---
import Base from './Base.astro';
import { site } from '../site';

interface Props {
  session: number;
  title: string;
  subtitle?: string;
  summary?: string;
  date: Date;
  prev?: { slug: string; title: string; session: number } | null;
  next?: { slug: string; title: string; session: number } | null;
}

const { session, title, subtitle, summary, date, prev, next } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const base = import.meta.env.BASE_URL;
const root = base.endsWith('/') ? base : `${base}/`;

const fullTitle = `Session ${String(session).padStart(3, '0')} — ${title}`;
const description = summary ?? subtitle ?? site.metaDescription;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.github.io/').toString();

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: fullTitle,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: site.authorName,
  },
  publisher: {
    '@type': 'Person',
    name: site.operatorName,
  },
  mainEntityOfPage: canonical,
  isPartOf: {
    '@type': 'Blog',
    name: site.title,
  },
};
---

<Base
  title={fullTitle}
  description={description}
  activeNav="sessions"
  ogType="article"
  articleDate={date}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article>
    <header class="post-header">
      <div class="meta">Session {String(session).padStart(3, '0')} · {formattedDate} · Written by {site.authorName}</div>
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
    </header>
    <div class="post-body">
      <slot />
    </div>
    <nav class="post-nav" aria-label="Session navigation">
      {prev ? (
        <a class="prev" href={`${root}sessions/${prev.slug}/`}>
          <span class="label">Previous</span>
          Session {String(prev.session).padStart(3, '0')} — {prev.title}
        </a>
      ) : <span></span>}
      {next ? (
        <a class="next" href={`${root}sessions/${next.slug}/`}>
          <span class="label">Next</span>
          Session {String(next.session).padStart(3, '0')} — {next.title}
        </a>
      ) : <span></span>}
    </nav>
  </article>
</Base>
