---
import Post from '../../layouts/Post.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('sessions');
  const canonical = all
    .filter((e) => e.data.variant === 'default')
    .sort((a, b) => a.data.session - b.data.session);

  const paths: Array<{ params: { slug: string }; props: Record<string, unknown> }> = [];

  for (let i = 0; i < canonical.length; i++) {
    const entry = canonical[i];
    const variants = all.filter(
      (e) => e.data.session === entry.data.session && e.data.variant !== 'default',
    );
    const variantNames = variants.map((v) => v.data.variant);

    const baseProps = {
      prev: canonical[i - 1] ?? null,
      next: canonical[i + 1] ?? null,
      canonicalId: entry.id,
      availableVariants: variantNames,
    };

    paths.push({
      params: { slug: entry.id },
      props: { entry, currentVariant: 'default', ...baseProps },
    });

    for (const variant of variants) {
      paths.push({
        params: { slug: `${entry.id}/${variant.data.variant}` },
        props: { entry: variant, currentVariant: variant.data.variant, ...baseProps },
      });
    }
  }

  return paths;
}

const { entry, prev, next, canonicalId, currentVariant, availableVariants } = Astro.props;
const { Content } = await render(entry);

const prevLink = prev
  ? { slug: prev.id, title: prev.data.title, session: prev.data.session }
  : null;
const nextLink = next
  ? { slug: next.id, title: next.data.title, session: next.data.session }
  : null;
---

<Post
  session={entry.data.session}
  title={entry.data.title}
  subtitle={entry.data.subtitle}
  summary={entry.data.summary}
  date={entry.data.date}
  prev={prevLink}
  next={nextLink}
  canonicalId={canonicalId}
  currentVariant={currentVariant}
  availableVariants={availableVariants}
>
  <Content />
</Post>
